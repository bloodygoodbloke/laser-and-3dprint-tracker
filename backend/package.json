{
  "name": "laser-and-3dprint-backend",
  "version": "0.6.0",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "prisma": "prisma",
    "check:release": "node ../scripts/check-release-notes.js",
    "check:tracker": "node ../scripts/check-tracker-consistency.js",
    "check:quality-cadence": "node ../scripts/check-quality-cadence.js",
    "preversion": "npm run check:release && npm run check:tracker && npm run check:quality-cadence"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "multer": "^1.4.5-lts.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.17",
    "@types/multer": "^1.4.7",
    "@types/node": "^20.14.2",
    "prisma": "^5.22.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.0"
  }
}
