generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model BillingSetting {
  id                      String   @id @default(cuid())
  businessName            String   @default("")
  businessLogoUrl         String   @default("")
  businessAddress         String   @default("")
  businessEmail           String   @default("")
  businessPhone           String   @default("")
  businessWebsite         String   @default("")
  adminBackgroundColor    String   @default("#0f172a")
  adminTextColor          String   @default("#e2e8f0")
  siteInputColor          String   @default("#111827")
  siteAccentColor         String   @default("#22d3ee")
  siteAccentTextColor     String   @default("#042f3a")
  materialMarkupPercent   Float    @default(0)
  materialMarkupAmount    Float    @default(0)
  materialTypeMarkups     String   @default("{}")
  electricityMarkupPercent Float   @default(0)
  electricityMarkupAmount  Float    @default(0)
  labourMarkupPercent     Float    @default(0)
  labourMarkupAmount      Float    @default(0)
  overheadMarkupPercent   Float    @default(0)
  overheadMarkupAmount    Float    @default(0)
  electricityCostPerKwh   Float    @default(0.2)
  depreciationCost        Float    @default(0)
  depreciationHours       Float    @default(0)
  depreciationMarkupPercent Float  @default(0)
  labourRate              Float    @default(20)
  workshopHourlyRate      Float    @default(0)
  minimumCharge           Float    @default(0)
  setupFee                Float    @default(0)
  rushFeePercent          Float    @default(0)
  wasteFactorPercent      Float    @default(0)
  deliveryAmount          Float    @default(0)
  vatPercent              Float    @default(0)
  depositPercent          Float    @default(0)
  paymentTermsDays        Int      @default(0)
  overheadPercent         Float    @default(0.15)
  machineElectricitySettings String @default("{}")
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
}

model Customer {
  id          String   @id @default(cuid())
  name        String
  address     String   @default("")
  email       String   @default("")
  phone       String   @default("")
  notes       String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Job {
  id              String            @id @default(cuid())
  jobNumber       String            @unique @default("")
  name            String
  customer        String?
  sourceUrl       String            @default("")
  filePath        String?
  machineType     String
  estTimeMinutes  Int
  machineRunTimeMinutes Int         @default(0)
  labourTimeMinutes Int             @default(0)
  dueDate         DateTime?
  queuePosition   Int               @default(0)
  qaChecklist     String            @default("[]")
  qaPassed        Boolean           @default(false)
  reworkCost      Float             @default(0)
  reworkNotes     String            @default("")
  isRush          Boolean           @default(false)
  paymentStatus   String            @default("Unpaid")
  depositPaidAmount Float           @default(0)
  status          String            @default("Pending")
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  materials       JobMaterial[]
  cost            JobCost?
  bambuStatuses   BambuMachineStatus[]
  bambuEvents     BambuEvent[]
  bambuUsageLogs  BambuUsageLog[]
  bambuFailureLogs BambuFailureLog[]
}

model Material {
  id               String         @id @default(cuid())
  name             String
  type             String
  unit             String
  color            String         @default("")
  costPerUnit      Float
  stockLevel       Float
  reorderThreshold Float
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  jobs             JobMaterial[]
}

model Supplier {
  id            String           @id @default(cuid())
  name          String
  contactEmail  String           @default("")
  contactPhone  String           @default("")
  notes         String           @default("")
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  purchases     MaterialPurchase[]
}

model BambuDevice {
  id                     String                     @id @default(cuid())
  name                   String
  serial                 String                     @unique
  ipAddress              String                     @default("")
  isOnline               Boolean                    @default(false)
  lastSeenAt             DateTime?
  createdAt              DateTime                   @default(now())
  updatedAt              DateTime                   @updatedAt
  statuses               BambuMachineStatus[]
  events                 BambuEvent[]
  spoolInventory         BambuSpoolInventory[]
  usageLogs              BambuUsageLog[]
  maintenancePredictions BambuMaintenancePrediction[]
  failureLogs            BambuFailureLog[]
}

model BambuMachineStatus {
  id           String      @id @default(cuid())
  deviceId     String
  device       BambuDevice @relation(fields: [deviceId], references: [id])
  jobId        String?
  job          Job?        @relation(fields: [jobId], references: [id])
  nozzleTempC  Float       @default(0)
  bedTempC     Float       @default(0)
  chamberTempC Float       @default(0)
  progressPct  Float       @default(0)
  amsSummary   String      @default("[]")
  errorCode    String      @default("")
  errorMessage String      @default("")
  reportedAt   DateTime    @default(now())

  @@index([deviceId, reportedAt])
}

model BambuEvent {
  id        String      @id @default(cuid())
  deviceId  String
  device    BambuDevice @relation(fields: [deviceId], references: [id])
  jobId     String?
  job       Job?        @relation(fields: [jobId], references: [id])
  eventType String
  payload   String      @default("{}")
  createdAt DateTime    @default(now())

  @@index([deviceId, createdAt])
}

model BambuSpoolInventory {
  id             String      @id @default(cuid())
  deviceId       String
  device         BambuDevice @relation(fields: [deviceId], references: [id])
  slotName       String
  materialName   String      @default("")
  color          String      @default("")
  remainingGrams Float       @default(0)
  updatedAt      DateTime    @updatedAt

  @@unique([deviceId, slotName])
}

model BambuUsageLog {
  id             String      @id @default(cuid())
  deviceId       String
  device         BambuDevice @relation(fields: [deviceId], references: [id])
  jobId          String?
  job            Job?        @relation(fields: [jobId], references: [id])
  runtimeMinutes Float       @default(0)
  materialGrams  Float       @default(0)
  source         String      @default("event")
  createdAt      DateTime    @default(now())

  @@index([deviceId, createdAt])
}

model BambuMaintenancePrediction {
  id                String      @id @default(cuid())
  deviceId          String
  device            BambuDevice @relation(fields: [deviceId], references: [id])
  component         String
  currentHours      Float       @default(0)
  intervalHours     Float       @default(0)
  predictedDueHours Float       @default(0)
  riskLevel         String      @default("Normal")
  updatedAt         DateTime    @updatedAt

  @@unique([deviceId, component])
}

model BambuFailureLog {
  id         String      @id @default(cuid())
  deviceId   String
  device     BambuDevice @relation(fields: [deviceId], references: [id])
  jobId      String?
  job        Job?        @relation(fields: [jobId], references: [id])
  errorCode  String      @default("")
  message    String      @default("")
  severity   String      @default("Warning")
  isResolved Boolean     @default(false)
  createdAt  DateTime    @default(now())
  resolvedAt DateTime?

  @@index([deviceId, createdAt])
}

model MaterialPurchase {
  id            String    @id @default(cuid())
  supplierId    String
  materialName  String
  quantityKg    Float     @default(0)
  totalCost     Float     @default(0)
  purchasedAt   DateTime  @default(now())
  notes         String    @default("")
  createdAt     DateTime  @default(now())
  supplier      Supplier  @relation(fields: [supplierId], references: [id])
}

model JobMaterial {
  id                 String   @id @default(cuid())
  jobId              String
  materialId         String
  usageQuantity      Float    @default(0)
  usageUnit          String   @default("g")
  usageUnitCost      Float    @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  job                Job      @relation(fields: [jobId], references: [id])
  material           Material @relation(fields: [materialId], references: [id])
}

model JobCost {
  id               String   @id @default(cuid())
  jobId            String   @unique
  materialCost     Float
  electricityCost  Float
  labourCost       Float
  overheadCost     Float
  totalCost        Float
  customerCharge   Float    @default(0)
  createdAt        DateTime @default(now())
  job              Job      @relation(fields: [jobId], references: [id])
}
