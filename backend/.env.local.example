# Copy this file to backend/.env.local and fill with your own values.
# backend/.env.local is git-ignored.

# Backend runtime
PORT=4000
APP_OWNER_OAUTH_REDIRECT_BASE=http://localhost:4000
APP_OWNER_SESSION_TTL_MS=28800000

# Owner identity matching (choose plain OR SHA-256 hash)
# Plain GitHub owner login
APP_OWNER_GITHUB_LOGIN=
# Hashed GitHub owner login (lowercase hex SHA-256 of login)
APP_OWNER_GITHUB_LOGIN_SHA256=

# Plain Microsoft owner email
APP_OWNER_MICROSOFT_EMAIL=
# Hashed Microsoft owner email (lowercase hex SHA-256 of email)
APP_OWNER_MICROSOFT_EMAIL_SHA256=

# GitHub OAuth app credentials
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# Microsoft OAuth app credentials
MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_CLIENT_SECRET=
